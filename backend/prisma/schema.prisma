// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  STUDENT
  TEACHER
  ADMIN
}

enum PowerUpType {
  FIFTY_FIFTY
  TIME_FREEZE
  DOUBLE_POINTS
  SHIELD
}

enum QuizVisibility {
  PRIVATE
  SHAREABLE
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String?
  role         UserRole
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  student       Student?
  teacher       Teacher?
  admin         Admin?
  sessions      Session[]
  refreshTokens RefreshToken[]
  notifications Notification[]
  createdQuizzes Quiz[]

  @@index([email])
}

model Student {
  id                 String @id @default(uuid())
  userId             String @unique
  user               User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  name               String
  registrationNumber String @unique
  course             String
  department         String
  branch             String
  year               Int
  section            String
  batch              String
  group              String
  collegeMailId      String

  quizParticipations QuizParticipation[]
  noteBookmarks      NoteBookmark[]
  noteAnnotations    NoteAnnotation[]
  examMarks          StudentExamMarks[]
  performances       StudentPerformance[]
  academicHealth     AcademicHealth?
  powerUps           PowerUp[]

  @@index([registrationNumber])
  @@index([year, section, batch])
  @@index([group])

  personalSlots PersonalSlot[]
  portalData    PortalData?
  classroomMemberships ClassroomMember[]
}

model Teacher {
  id         String   @id @default(uuid())
  userId     String   @unique
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name       String
  department String
  subjects   String[]

  lectureNotes LectureNote[]
  quizzes      Quiz[]
  assignments  Assignment[]
  exams        Exam[]
  sectionAssignments SectionTeacher[]
  classrooms   Classroom[]

  @@index([department])
}

model Admin {
  id     String @id @default(uuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  name   String
}

model Session {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([token])
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([token])
}

model LectureNote {
  id          String   @id @default(uuid())
  teacherId   String
  teacher     Teacher  @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  subject     String
  topic       String
  title       String
  description String?
  fileUrl     String
  fileType    String
  lectureDate DateTime
  uploadedAt  DateTime @default(now())

  bookmarks   NoteBookmark[]
  annotations NoteAnnotation[]

  @@index([subject, topic])
  @@index([teacherId])
  @@index([lectureDate])
  @@index([subject, lectureDate])
}

model NoteBookmark {
  id        String      @id @default(uuid())
  studentId String
  student   Student     @relation(fields: [studentId], references: [id], onDelete: Cascade)
  noteId    String
  note      LectureNote @relation(fields: [noteId], references: [id], onDelete: Cascade)
  createdAt DateTime    @default(now())

  @@unique([studentId, noteId])
  @@index([studentId])
}

model NoteAnnotation {
  id        String      @id @default(uuid())
  studentId String
  student   Student     @relation(fields: [studentId], references: [id], onDelete: Cascade)
  noteId    String
  note      LectureNote @relation(fields: [noteId], references: [id], onDelete: Cascade)
  content   String
  page      Int?
  positionX Float?
  positionY Float?
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  @@index([studentId, noteId])
}

model Quiz {
  id              String   @id @default(uuid())
  teacherId       String?
  teacher         Teacher? @relation(fields: [teacherId], references: [id], onDelete: SetNull)
  authorId        String
  author          User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  title           String
  subject         String
  questions       Json
  timePerQuestion Int
  visibility      QuizVisibility @default(PRIVATE)
  createdAt       DateTime @default(now())
  lastPlayedAt    DateTime?

  sessions QuizSession[]

  @@index([teacherId])
  @@index([authorId])
  @@index([subject])
  @@index([createdAt])
  @@index([visibility])
}

model QuizSession {
  id                   String    @id @default(uuid())
  quizId               String
  quiz                 Quiz      @relation(fields: [quizId], references: [id], onDelete: Cascade)
  sessionCode          String    @unique
  qrCodeUrl            String
  status               String
  currentQuestionIndex Int       @default(0)
  startedAt            DateTime  @default(now())
  endedAt              DateTime?

  participations QuizParticipation[]
  powerUps       PowerUp[]

  @@index([sessionCode])
  @@index([quizId])
  @@index([status])
  @@index([startedAt])
}

model QuizParticipation {
  id          String      @id @default(uuid())
  sessionId   String
  session     QuizSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  studentId   String
  student     Student     @relation(fields: [studentId], references: [id], onDelete: Cascade)
  answers     Json
  score       Int
  rank        Int
  completedAt DateTime    @default(now())

  @@unique([sessionId, studentId])
  @@index([studentId])
}

model PowerUp {
  id        String      @id @default(uuid())
  sessionId String
  session   QuizSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  studentId String
  student   Student     @relation(fields: [studentId], references: [id], onDelete: Cascade)
  type      PowerUpType
  used      Boolean     @default(false)
  usedAt    DateTime?
  createdAt DateTime    @default(now())

  @@unique([sessionId, studentId, type])
  @@index([sessionId, studentId])
  @@index([studentId])
}

model Assignment {
  id          String   @id @default(uuid())
  teacherId   String
  teacher     Teacher  @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  subject     String
  topic       String
  title       String
  description String
  fileUrl     String?
  dueDate     DateTime
  maxMarks    Int
  createdAt   DateTime @default(now())

  @@index([teacherId])
  @@index([subject])
  @@index([dueDate])
  @@index([subject, dueDate])
}

model Exam {
  id         String   @id @default(uuid())
  teacherId  String
  teacher    Teacher  @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  subject    String
  examName   String
  examDate   DateTime
  totalMarks Int
  questions  Json
  createdAt  DateTime @default(now())

  marks StudentExamMarks[]

  @@index([teacherId])
  @@index([subject])
  @@index([examDate])
  @@index([subject, examDate])
}

model StudentExamMarks {
  id            String   @id @default(uuid())
  examId        String
  exam          Exam     @relation(fields: [examId], references: [id], onDelete: Cascade)
  studentId     String
  student       Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  questionMarks Json
  totalMarks    Int
  percentage    Float
  topicScores   Json
  recordedAt    DateTime @default(now())

  @@unique([examId, studentId])
  @@index([studentId])
}

model StudentPerformance {
  id             String   @id @default(uuid())
  studentId      String
  student        Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  subject        String
  topic          String
  assessmentType String
  score          Float
  maxScore       Float
  percentage     Float
  assessmentDate DateTime
  createdAt      DateTime @default(now())

  @@index([studentId, subject, topic])
  @@index([studentId, assessmentDate])
  @@index([studentId, subject])
  @@index([subject, topic])
}

model AcademicHealth {
  id               String   @id @default(uuid())
  studentId        String   @unique
  student          Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  overallScore     Float
  quizScore        Float
  assignmentScore  Float
  examScore        Float
  consistencyScore Float
  weakSubjects     String[]
  weakTopics       Json
  calculatedAt     DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model CalendarDay {
  id           String   @id @default(uuid())
  date         DateTime 
  dayOrder     Int?     // Null = Holiday
  name         String?  // Holiday Name (e.g. "Pongal")
  version      Int      @default(1)
  isActive     Boolean  @default(true)
  isCancelled  Boolean  @default(false)
  
  @@unique([date, version])
  @@index([date, isActive])
}

model UnifiedSlot {
  id           String   @id @default(uuid())
  batch        String   // "Batch 1", "Batch 2"
  dayOrder     Int
  period       Int      // 1-12
  slots        String[] // ["A", "X"]
  startTime    Int      // Minutes from midnight
  endTime      Int      // Minutes from midnight
  version      Int      @default(1)
  isActive     Boolean  @default(true)
  isCancelled  Boolean  @default(false)

  @@unique([batch, dayOrder, period, version])
  @@index([batch, dayOrder, isActive])
}

model PersonalSlot {
  id            String   @id @default(uuid())
  studentId     String
  slots         String[] // ["P47", "P48"]
  normalizedKey String   // "P47,P48" for uniqueness
  subject       String
  room          String
  type          String   // "theory", "lab"
  isCancelled   Boolean  @default(false)
  
  student       Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  @@unique([studentId, normalizedKey])
  @@index([studentId])
}

// ─── Portal Synced Data ───────────────────────────────────────────────────────

model PortalData {
  id          String   @id @default(uuid())
  studentId   String   @unique
  student     Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  // Attendance: { subject: string, attended: number, total: number, percentage: number }[]
  attendance  Json     @default("[]")
  // Marks: { subject: string, assessments: { name: string, scored: number, max: number }[] }[]
  marks       Json     @default("[]")
  // Raw timetable slots from portal
  timetable   Json     @default("[]")
  syncedAt    DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ─── Classroom (Teacher-created, invite-only) ─────────────────────────────────

model Classroom {
  id          String   @id @default(uuid())
  teacherId   String
  teacher     Teacher  @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  name        String
  subject     String
  inviteCode  String   @unique
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  members     ClassroomMember[]
  sketchBoards SketchBoard[]

  @@index([teacherId])
  @@index([inviteCode])
}

model ClassroomMember {
  id          String    @id @default(uuid())
  classroomId String
  classroom   Classroom @relation(fields: [classroomId], references: [id], onDelete: Cascade)
  studentId   String
  student     Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  status      String    @default("PENDING") // PENDING | APPROVED | REJECTED
  joinedAt    DateTime  @default(now())

  @@unique([classroomId, studentId])
  @@index([classroomId])
  @@index([studentId])
}

// ─── Sketch Board ─────────────────────────────────────────────────────────────

model SketchBoard {
  id          String    @id @default(uuid())
  classroomId String
  classroom   Classroom @relation(fields: [classroomId], references: [id], onDelete: Cascade)
  title       String    @default("Untitled Board")
  // Stored as JSON array of drawing strokes
  data        Json      @default("[]")
  shareToken  String    @unique
  isLive      Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([classroomId])
  @@index([shareToken])
}

model Timetable {
  id          String   @id @default(uuid())
  year        Int
  batch       String
  fileUrl     String
  schedule    Json
  uploadedAt  DateTime @default(now())
  processedAt DateTime @default(now())

  @@unique([year, batch])
}

model SectionTimetable {
  id          String   @id @default(uuid())
  year        Int
  section     String
  batch       String
  department  String
  schedule    Json     // Detailed mapping: { "Day1": [{ slot, subject, venue, faculty }, ...] }
  uploadedAt  DateTime @default(now())
  processedAt DateTime @default(now())

  @@unique([year, section, batch, department])
}

model AcademicCalendar {
  id              String   @id @default(uuid())
  academicYear    String
  fileUrl         String
  dayOrderMapping Json
  uploadedAt      DateTime @default(now())
  processedAt     DateTime @default(now())
}

enum NotificationType {
  NEW_LECTURE_NOTE
  QUIZ_STARTED
  QUIZ_SCHEDULED
  ASSIGNMENT_POSTED
  PERFORMANCE_ALERT
  SYSTEM_ANNOUNCEMENT
}

model Notification {
  id        String           @id @default(uuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType
  title     String
  message   String
  actionUrl String?
  metadata  Json?
  read      Boolean          @default(false)
  createdAt DateTime         @default(now())

  @@index([userId, read])
  @@index([createdAt])
}

model NotificationPreferences {
  id                String   @id @default(uuid())
  userId            String   @unique
  enableInApp       Boolean  @default(true)
  notificationTypes Json
  updatedAt         DateTime @updatedAt
}
model SectionTeacher {
  id         String   @id @default(uuid())
  teacherId  String
  teacher    Teacher  @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  year       Int
  section    String
  department String
  createdAt  DateTime @default(now())

  @@unique([teacherId, year, section, department])
  @@index([year, section, department])
}

model SectionPost {
  id         String   @id @default(uuid())
  year       Int
  section    String
  department String
  sectionKey String?  // Denormalized: "{year}-{section}-{department}"
  authorId   String   // Can be User ID (Student or Teacher)
  authorName String
  content    String
  attachments Json?    // Array of file URLs
  createdAt  DateTime @default(now())

  comments   SectionComment[]

  @@index([year, section, department])
  @@index([sectionKey])
  @@index([createdAt])
}

model SectionComment {
  id         String      @id @default(uuid())
  postId     String
  post       SectionPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  authorId   String
  authorName String
  content    String
  createdAt  DateTime    @default(now())

  @@index([postId])
  @@index([createdAt])
}

// ─── AI Provider Configuration ───────────────────────────────────────────────

enum AIProvider {
  OPENAI
  GEMINI
  CUSTOM
}

model AIProviderConfig {
  id        String     @id @default(uuid())
  userId    String     @unique
  provider  AIProvider @default(OPENAI)
  apiKey    String     // Encrypted at rest via application-level AES-256
  baseUrl   String?    // Required for CUSTOM provider
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@index([userId])
}

// ─── Mock Test Models ─────────────────────────────────────────────────────────

enum MockTestDifficulty {
  EASY
  MEDIUM
  HARD
}

model MockTest {
  id            String              @id @default(uuid())
  authorId      String
  name          String
  subject       String
  topics        String[]
  questions     Json                // QuizQuestion[]
  difficulty    MockTestDifficulty  @default(MEDIUM)
  questionCount Int
  // Assignment fields (teacher only)
  assignedSection   String?         // e.g. "A"
  assignedYear      Int?
  assignedDept      String?
  windowStart       DateTime?
  windowEnd         DateTime?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  attempts MockTestAttempt[]

  @@index([authorId])
  @@index([subject])
  @@index([createdAt])
}

model MockTestAttempt {
  id          String   @id @default(uuid())
  testId      String
  test        MockTest @relation(fields: [testId], references: [id], onDelete: Cascade)
  studentId   String
  answers     Json     // { questionId: string, selectedOption: number }[]
  score       Int
  totalPoints Int
  timeTaken   Int      // seconds
  startedAt   DateTime @default(now())
  submittedAt DateTime?
  violations  Json     @default("[]") // { type: string, timestamp: string }[]

  @@unique([testId, studentId])
  @@index([testId])
  @@index([studentId])
}
