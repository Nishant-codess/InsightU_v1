// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  STUDENT
  TEACHER
  ADMIN
  PARENT
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}



model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String?
  role         UserRole
  srmEmail     String?  // SRM Academia email
  srmPassword  String?  // SRM Academia password (TODO: encrypt in production)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  student       Student?
  teacher       Teacher?
  admin         Admin?
  parent        Parent?
  sessions      Session[]
  refreshTokens RefreshToken[]

  @@index([email])
  @@index([srmEmail])
}

model Student {
  id                 String @id @default(uuid())
  userId             String @unique
  user               User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  name               String
  registrationNumber String @unique
  course             String
  department         String
  branch             String
  year               Int
  section            String
  batch              String
  group              String
  collegeMailId      String

  @@index([registrationNumber])
  @@index([year, section, batch])
  @@index([group])

  personalSlots        PersonalSlot[]
  portalData           PortalData?
  classroomMemberships ClassroomMember[]
  whiteboardMemberships WhiteboardMember[]
}

model Teacher {
  id              String          @id @default(uuid())
  userId          String          @unique
  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  name            String
  department      String
  subjects        String[]
  idCardUrl       String?         // ID card image
  approvalStatus  ApprovalStatus  @default(PENDING)
  approvedAt      DateTime?
  approvedBy      String?         // Admin user ID
  rejectionReason String?

  classrooms   Classroom[]

  @@index([department])
  @@index([approvalStatus])
}

model Admin {
  id     String @id @default(uuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  name   String
}

model Parent {
  id              String          @id @default(uuid())
  userId          String          @unique
  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  name            String
  phone           String?
  childSrmEmail   String          // Child's SRM email
  childSrmPassword String         // Child's SRM password (encrypted)
  childIdCardUrl  String?         // Child's ID card
  approvalStatus  ApprovalStatus  @default(PENDING)
  approvedAt      DateTime?
  approvedBy      String?         // Admin user ID
  rejectionReason String?
  createdAt       DateTime        @default(now())

  @@index([approvalStatus])
  @@index([childSrmEmail])
}

model Session {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([token])
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([token])
}



model CalendarDay {
  id           String   @id @default(uuid())
  date         DateTime 
  dayOrder     Int?     // Null = Holiday
  name         String?  // Holiday Name (e.g. "Pongal")
  version      Int      @default(1)
  isActive     Boolean  @default(true)
  isCancelled  Boolean  @default(false)
  
  @@unique([date, version])
  @@index([date, isActive])
}

model UnifiedSlot {
  id           String   @id @default(uuid())
  batch        String   // "Batch 1", "Batch 2"
  dayOrder     Int
  period       Int      // 1-12
  slots        String[] // ["A", "X"]
  startTime    Int      // Minutes from midnight
  endTime      Int      // Minutes from midnight
  version      Int      @default(1)
  isActive     Boolean  @default(true)
  isCancelled  Boolean  @default(false)

  @@unique([batch, dayOrder, period, version])
  @@index([batch, dayOrder, isActive])
}

model PersonalSlot {
  id            String   @id @default(uuid())
  studentId     String
  slots         String[] // ["P47", "P48"]
  normalizedKey String   // "P47,P48" for uniqueness
  subject       String
  room          String
  type          String   // "theory", "lab"
  isCancelled   Boolean  @default(false)
  
  student       Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  @@unique([studentId, normalizedKey])
  @@index([studentId])
}

// ─── Portal Synced Data ───────────────────────────────────────────────────────

model PortalData {
  id          String   @id @default(uuid())
  studentId   String   @unique
  student     Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  // Attendance: { subject: string, attended: number, total: number, percentage: number }[]
  attendance  Json     @default("[]")
  // Marks: { subject: string, assessments: { name: string, scored: number, max: number }[] }[]
  marks       Json     @default("[]")
  // Raw timetable slots from portal
  timetable   Json     @default("[]")
  syncedAt    DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ─── Classroom (GCR-style, Teacher-created, invite-only) ──────────────────────

model Classroom {
  id          String   @id @default(uuid())
  teacherId   String
  teacher     Teacher  @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  name        String
  subject     String
  description String?
  inviteCode  String   @unique
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  members      ClassroomMember[]
  posts        ClassroomPost[]
  whiteboards  Whiteboard[]

  @@index([teacherId])
  @@index([inviteCode])
}

model ClassroomMember {
  id          String    @id @default(uuid())
  classroomId String
  classroom   Classroom @relation(fields: [classroomId], references: [id], onDelete: Cascade)
  studentId   String
  student     Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  status      String    @default("PENDING") // PENDING | APPROVED | REJECTED
  joinedAt    DateTime  @default(now())
  approvedAt  DateTime?

  @@unique([classroomId, studentId])
  @@index([classroomId])
  @@index([studentId])
  @@index([status])
}

// ─── Classroom Posts (Links, Files, Announcements) ────────────────────────────

model ClassroomPost {
  id          String    @id @default(uuid())
  classroomId String
  classroom   Classroom @relation(fields: [classroomId], references: [id], onDelete: Cascade)
  authorId    String    // Teacher User ID
  authorName  String
  title       String?
  content     String
  links       Json      @default("[]") // Array of { url: string, title: string }
  attachments Json      @default("[]") // Array of { url: string, name: string, type: string, size: number }
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([classroomId])
  @@index([createdAt])
}

// ─── Whiteboard (Code Sharing, invite-only) ───────────────────────────────────

model Whiteboard {
  id          String    @id @default(uuid())
  classroomId String?
  classroom   Classroom? @relation(fields: [classroomId], references: [id], onDelete: Cascade)
  teacherId   String
  title       String    @default("Untitled Whiteboard")
  description String?
  inviteCode  String    @unique
  // Code content stored as JSON: { language: string, code: string }
  content     Json      @default("{}")
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  members     WhiteboardMember[]

  @@index([teacherId])
  @@index([inviteCode])
  @@index([classroomId])
}

model WhiteboardMember {
  id           String     @id @default(uuid())
  whiteboardId String
  whiteboard   Whiteboard @relation(fields: [whiteboardId], references: [id], onDelete: Cascade)
  studentId    String
  student      Student    @relation(fields: [studentId], references: [id], onDelete: Cascade)
  status       String     @default("PENDING") // PENDING | APPROVED | REJECTED
  joinedAt     DateTime   @default(now())
  approvedAt   DateTime?

  @@unique([whiteboardId, studentId])
  @@index([whiteboardId])
  @@index([studentId])
  @@index([status])
}

model Timetable {
  id          String   @id @default(uuid())
  year        Int
  batch       String
  fileUrl     String
  schedule    Json
  uploadedAt  DateTime @default(now())
  processedAt DateTime @default(now())

  @@unique([year, batch])
}

model SectionTimetable {
  id          String   @id @default(uuid())
  year        Int
  section     String
  batch       String
  department  String
  schedule    Json     // Detailed mapping: { "Day1": [{ slot, subject, venue, faculty }, ...] }
  uploadedAt  DateTime @default(now())
  processedAt DateTime @default(now())

  @@unique([year, section, batch, department])
}

// ─── AI Provider Configuration ───────────────────────────────────────────────

enum AIProvider {
  OPENAI
  GEMINI
  CUSTOM
}

model AIProviderConfig {
  id        String     @id @default(uuid())
  userId    String     @unique
  provider  AIProvider @default(OPENAI)
  apiKey    String     // Encrypted at rest via application-level AES-256
  baseUrl   String?    // Required for CUSTOM provider
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@index([userId])
}

// ─── Mock Test Models ─────────────────────────────────────────────────────────

enum MockTestDifficulty {
  EASY
  MEDIUM
  HARD
}

model MockTest {
  id            String              @id @default(uuid())
  authorId      String
  name          String
  subject       String
  topics        String[]
  questions     Json                // QuizQuestion[]
  difficulty    MockTestDifficulty  @default(MEDIUM)
  questionCount Int
  // Assignment fields (teacher only)
  assignedSection   String?         // e.g. "A"
  assignedYear      Int?
  assignedDept      String?
  windowStart       DateTime?
  windowEnd         DateTime?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  attempts MockTestAttempt[]

  @@index([authorId])
  @@index([subject])
  @@index([createdAt])
}

model MockTestAttempt {
  id          String   @id @default(uuid())
  testId      String
  test        MockTest @relation(fields: [testId], references: [id], onDelete: Cascade)
  studentId   String
  answers     Json     // { questionId: string, selectedOption: number }[]
  score       Int
  totalPoints Int
  timeTaken   Int      // seconds
  startedAt   DateTime @default(now())
  submittedAt DateTime?
  violations  Json     @default("[]") // { type: string, timestamp: string }[]

  @@unique([testId, studentId])
  @@index([testId])
  @@index([studentId])
}
